# /opt/tita-api/.env — production environment (render từ GHA secrets task 11).
# KHÔNG commit thật. Đây là template.

NODE_ENV=production
PORT=3002

# === PostgreSQL ===
POSTGRES_URL=postgresql://tita_app:__PG_PASSWORD__@127.0.0.1:5432/tita_prod
PG_POOL_MAX=20
PG_POOL_MIN=4

# === Redis ===
REDIS_URL=redis://default:__REDIS_PASSWORD__@127.0.0.1:6379
USE_REDIS_CACHE=true

# === AWS ===
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=__AWS_APP_KEY_ID__
AWS_SECRET_ACCESS_KEY=__AWS_APP_SECRET__
S3_BUCKET=tienthanh-app-data
S3_KEY=__AWS_APP_KEY_ID__
S3_SECRET=__AWS_APP_SECRET__

# === CloudFront signed URL (S3 task 05 + S4 task 10) ===
CDN_BASE=https://tienthanhcdn.datviet.ai
CF_KEY_PAIR_ID=__CF_KEY_PAIR_ID__
CF_PRIVATE_KEY=__CF_PRIVATE_KEY_BASE64__   # base64-encoded PEM

# === SES ===
SES_FROM=noreply@tienthanh.datviet.ai

# === FE ===
FRONTEND_URL=https://tienthanh.datviet.ai

# === Cron ===
ENABLE_CRON=1

# === Misc ===
TZ=Asia/Ho_Chi_Minh
LOG_LEVEL=info
